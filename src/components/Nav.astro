---
<nav class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">
      <span class="logo-rl">RL</span>
      <span class="logo-text">Richer Living</span>
    </a>
    <div class="nav-links">
      <a href="#levers">The Framework</a>
      <a href="#newsletter">Newsletter</a>
      <a href="https://x.com/Richer_Living" target="_blank" rel="noopener">X</a>
      <a href="#subscribe" class="btn btn-primary nav-cta">Join Free</a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1.25rem 0;
    background: rgba(10, 22, 40, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(212, 175, 55, 0.1);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-rl {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    background: var(--gold);
    color: var(--navy);
    font-weight: 800;
    font-size: 0.9rem;
    border-radius: 4px;
    letter-spacing: -0.02em;
  }

  .logo-text {
    font-weight: 600;
    font-size: 1rem;
    color: var(--white);
    letter-spacing: 0.01em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-links a {
    color: var(--gray-light);
    font-size: 0.9rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover {
    color: var(--white);
  }

  .nav-cta {
    padding: 0.6rem 1.4rem !important;
    font-size: 0.875rem !important;
    color: var(--navy) !important;
  }

  @media (max-width: 768px) {
    .nav-links a:not(.nav-cta) {
      display: none;
    }
  }
</style>
